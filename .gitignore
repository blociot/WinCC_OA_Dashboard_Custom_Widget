# WinCC OA runtime data — changes constantly, not source code
# db/ contains the PostgreSQL database files (binary, modified every time the project runs)
db/

# cache/ contains gzipped copies of dashboard files generated by the WinCC OA web server
cache/

# log/ contains runtime log files from WinCC OA managers
log/

# Build output — regenerated by npm run build in webui-dev/
# This entire directory is recreated from source every build, so no need to track it
data/dashboard-wc/

# npm dependencies — reinstalled by npm install
# This folder can contain 50,000+ files and is fully reproducible from package-lock.json
webui-dev/node_modules/

# Node/Vite temp files used during builds
webui-dev/.nx/
webui-dev/node_modules/.vite/

# OS-generated files
Thumbs.db
Desktop.ini
.DS_Store